{
    "name": "knifelemon/lguplus-centrex-restapi",
    "description": "LG U+ Centrex REST API PHP client library",
    "type": "library",
    "keywords": ["lguplus", "centrex", "restapi", "telephony"],
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "LGUPlus\\Centrex\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LGUPlus\\Centrex\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
